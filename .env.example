# ─────────────────────────────────────────────────────────────
# CyberGuard AI — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no Git
# ─────────────────────────────────────────────────────────────

# ── IA (opcional) ────────────────────────────────────────────
# Deixe em branco para usar o modo offline (sem API)
ANTHROPIC_API_KEY=

# ── Configurações do sistema ──────────────────────────────────
APP_NAME=CyberGuard AI
APP_VERSION=1.0.0
DEBUG=false

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL=sqlite:///cyberguard.db

# ── Limites de detecção (personalizáveis) ─────────────────────
BRUTE_FORCE_THRESHOLD=5        # falhas para classificar como brute force
BRUTE_FORCE_WINDOW_MINUTES=10  # janela de tempo em minutos
SUCCESS_AFTER_FAIL_THRESHOLD=3 # falhas antes de um sucesso suspeito
SUSPICIOUS_IP_USER_THRESHOLD=3 # usuários distintos por IP
OFF_HOURS_START=22             # hora de início do período suspeito (22h)
OFF_HOURS_END=7                # hora de fim do período suspeito (7h)

# ── Relatório ─────────────────────────────────────────────────
REPORT_OUTPUT_DIR=reports/
MAX_UPLOAD_SIZE_MB=50
